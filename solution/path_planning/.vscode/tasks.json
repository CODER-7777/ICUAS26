{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C++ Solver",
            "type": "cppbuild",
            "command": "g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "main.cpp", // Compile main.cpp
                "-o",
                "solver.exe", // Output solver.exe
                "-std=c++17", // Use C++17
                "-lm"         // Link math library
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Builds the C++ solver using g++"
        }
    ]
}