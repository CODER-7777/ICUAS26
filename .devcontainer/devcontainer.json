{
  "name": "CrazySim ICUAS Environment",
  "image": "crazysim_icuas_img",
  
  "initializeCommand": "bash ./host_setup.sh",

  "workspaceMount": "source=${localWorkspaceFolder},target=/root/icuas26_competition,type=bind",
  "workspaceFolder": "/root/icuas26_competition",

  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}",
    "QT_X11_NO_MITSHM": "1",
    "TERM": "xterm-256color",
    "SSH_AUTH_SOCK": "/ssh-agent",
    "QT_QPA_PLATFORM": "xcb" 
  },

  "runArgs": [
    "--net=host",
    "--privileged",
    "--gpus", "all,\"capabilities=compute,utility,graphics\"",
    "--name=crazysim_icuas_cont" 
  ],

  "mounts": [
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",
    "source=/dev,target=/dev,type=bind",
    "source=/var/run/dbus,target=/var/run/dbus,type=bind",
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,readonly"
  ],

  "customizations": {
    "jetbrains": {
      "backend": "CLion"
    }
  }
}
